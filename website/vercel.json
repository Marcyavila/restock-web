{
  "headers": [
    { "source": "/auth/(.*)", "headers": [{ "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://getrestock.app https://www.getrestock.app chrome-extension:" }] },
    { "source": "/auth", "headers": [{ "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://getrestock.app https://www.getrestock.app chrome-extension:" }] }
  ],
  "rewrites": [
    { "source": "/auth/assets/:path*", "destination": "/auth-build/assets/:path*" },
    { "source": "/auth", "destination": "/auth-build/index.html" },
    { "source": "/auth/:path*", "destination": "/auth-build/index.html" },
    { "source": "/upgrade", "destination": "/upgrade.html" }
  ]
}
