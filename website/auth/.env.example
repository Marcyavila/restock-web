# Copy this file to .env and replace the placeholders with your real values.
# File location: website/auth/.env (this folder, same level as package.json)

# From Clerk Dashboard → your app → API Keys → Publishable key (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Convex HTTP URL (from Convex Dashboard → your project → Settings/URLs).
# The extension uses this; the auth app only needs it if you use Convex here later.
# VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
